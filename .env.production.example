# ============================================================
# CẤU HÌNH PRODUCTION — sao chép file này thành .env.production rồi sửa giá trị
#     cp .env.production.example .env.production
#     nano .env.production
# TUYỆT ĐỐI KHÔNG commit file .env.production lên git (đã được .gitignore).
# ============================================================

# ── Domain (BẮT BUỘC) ──
# Tên miền đã trỏ A record về IP VPS. Caddy dùng giá trị này để xin HTTPS.
DOMAIN=forum.example.com

# URL công khai của site (dùng cho CORS). Thường là https://<DOMAIN>
FRONTEND_URL=https://forum.example.com

# ── Cơ sở dữ liệu (BẮT BUỘC) ──
POSTGRES_USER=forum
POSTGRES_DB=forum
# Đặt MẬT KHẨU MẠNH (tạo bằng: openssl rand -base64 24)
POSTGRES_PASSWORD=DOI_MAT_KHAU_NAY

# ── Bảo mật JWT (BẮT BUỘC) ──
# Tạo mỗi khoá bằng: openssl rand -base64 48
JWT_ACCESS_SECRET=DOI_CHUOI_BI_MAT_NAY
JWT_REFRESH_SECRET=DOI_CHUOI_BI_MAT_KHAC
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Tự seed dữ liệu mẫu lần đầu chạy (categories, AI, vật phẩm…). Sau khi chạy ổn có thể đặt false.
AUTO_SEED=true

# ── AI (TUỲ CHỌN) — để trống nếu chưa dùng tính năng AI ──
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=

# ── Thanh toán (TUỲ CHỌN) ──
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NAME=
SEPAY_WEBHOOK_API_KEY=
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ── Lưu trữ media qua MinIO/S3 (TUỲ CHỌN) ──
# Để trống nếu chỉ dùng ảnh bằng URL bên ngoài. Bật nếu muốn người dùng upload file trực tiếp.
MEDIA_ENDPOINT=
MEDIA_REGION=us-east-1
MEDIA_BUCKET=
MEDIA_ACCESS_KEY=
MEDIA_SECRET_KEY=
MEDIA_FORCE_PATH_STYLE=true
MEDIA_PUBLIC_URL=
