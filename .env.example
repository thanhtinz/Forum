# Database
DATABASE_URL="postgresql://user:password@localhost:5432/forum?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Frontend
FRONTEND_URL="http://localhost:3000"
PORT=3001

# AI Providers
OPENAI_API_KEY=""
GEMINI_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# SePay
SEPAY_BANK_ACCOUNT=""
SEPAY_BANK_NAME=""
SEPAY_ACCOUNT_NAME=""
SEPAY_WEBHOOK_API_KEY="change-me-webhook-key"

# PayPal
PAYPAL_MODE="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""

# Media / S3 / MinIO (MediaService đọc các biến MEDIA_*)
MEDIA_ENDPOINT="http://localhost:9000"
MEDIA_REGION="us-east-1"
MEDIA_BUCKET="forum-media"
MEDIA_ACCESS_KEY="minioadmin"
MEDIA_SECRET_KEY="minioadmin"
MEDIA_FORCE_PATH_STYLE="true"
MEDIA_PUBLIC_URL="http://localhost:9000/forum-media"

# Tự seed dữ liệu mẫu khi khởi động (đặt false để tắt)
AUTO_SEED="true"

# Redis
REDIS_URL="redis://localhost:6379"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_KEY=""
